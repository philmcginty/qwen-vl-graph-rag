# Qwen VL embedding server
QVLRAG_QWEN_URL=http://localhost:8000

# Neo4j
QVLRAG_NEO4J_URI=bolt://localhost:7687
QVLRAG_NEO4J_USER=neo4j
QVLRAG_NEO4J_PASS=your_password_here

# Path to the image library you want to ingest
QVLRAG_LIBRARY_ROOT=/path/to/your/images

# API server
QVLRAG_API_HOST=127.0.0.1
QVLRAG_API_PORT=8001
